{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://lovenote.example.com",
          "http://localhost:4321"
        ],
        "methods": ["PUT"],
        "headers": ["Content-Type", "If-None-Match"]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
