---
import { actions, isInputError } from 'astro:actions';

import PostBody from '../../components/PostBody.astro';
import { listModeratablePosts, MODERATABLE_POST_LIMIT } from '../../db/post-moderation-queries';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isOwner } from '../../lib/authorization';

Astro.cache.set(false);
Astro.response.headers.set('Cache-Control', 'private, no-store');
Astro.response.headers.set('Pragma', 'no-cache');

if (!Astro.locals.user) {
	return Astro.redirect('/login');
}

const owner = isOwner(Astro.locals.user);
if (!owner) Astro.response.status = 403;

const hideResult = Astro.getActionResult(actions.postLifecycle.hide);
const restoreResult = Astro.getActionResult(actions.postLifecycle.restore);
const deletionResult = Astro.getActionResult(actions.postDeletion.delete);
const lifecycleResult = hideResult ?? restoreResult;
const posts = owner ? await listModeratablePosts(Astro.locals.database) : [];
const lifecycleSuccess = lifecycleResult?.data?.cachePurged
	? `Post #${lifecycleResult.data.postId} is now ${lifecycleResult.data.status}.`
	: null;
const lifecycleCacheWarning = lifecycleResult?.data?.cachePurged === false
	? lifecycleResult.data
	: null;
const lifecycleError = lifecycleResult?.error
	? isInputError(lifecycleResult.error)
		? 'The post moderation request was invalid.'
		: lifecycleResult.error.message
	: null;
const deletionSuccess = deletionResult?.data?.completed
	? `Post #${deletionResult.data.postId} was permanently deleted.`
	: null;
const deletionWarning = deletionResult?.data?.completed === false
	? deletionResult.data
	: null;
const deletionError = deletionResult?.error
	? isInputError(deletionResult.error)
		? 'Confirm permanent deletion before continuing.'
		: deletionResult.error.message
	: null;
const deletionPhaseMessage = {
	cache: 'Its cached copies could not be cleared.',
	database: 'Its database record could not be finalized.',
	storage: 'One or more media files could not be removed from storage.',
} as const;
const formatDateTime = (date: Date) => new Intl.DateTimeFormat('en-US', {
	dateStyle: 'medium',
	timeStyle: 'short',
	timeZone: 'UTC',
}).format(date);
---

<BaseLayout title="Moderate posts · LoveNote">
	<header class="border-b border-stone-200 bg-white">
		<div class="mx-auto flex w-full max-w-4xl items-center justify-between px-5 py-4 sm:px-8">
			<a href="/" class="font-semibold tracking-tight text-stone-950">LoveNote</a>
			<nav class="flex items-center gap-4 text-sm" aria-label="Owner navigation">
				<a href="/owner/tags" class="text-stone-600 hover:text-stone-950">Tags</a>
				<a href="/owner/comments" class="text-stone-600 hover:text-stone-950">Comments</a>
				<a href="/owner/users" class="text-stone-600 hover:text-stone-950">Members</a>
				<a href="/account" class="text-stone-600 hover:text-stone-950">Account</a>
			</nav>
		</div>
	</header>

	<main class="mx-auto w-full max-w-4xl px-5 py-10 sm:px-8">
		<p class="text-sm font-semibold tracking-[0.16em] text-rosewood uppercase">Owner moderation</p>
		<h1 class="mt-2 text-3xl font-semibold tracking-tight text-stone-950">Posts</h1>

		{!owner ? (
			<p class="mt-7 rounded-2xl border border-red-200 bg-red-50 p-5 text-red-900" role="alert">Only the owner can moderate every post.</p>
		) : (
			<>
				<p class="mt-3 text-stone-600">Review the {MODERATABLE_POST_LIMIT} newest posts across all authors, visibility settings, and cleanup states.</p>

				{lifecycleSuccess && (
					<p class="mt-7 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900" role="status">{lifecycleSuccess}</p>
				)}
				{lifecycleError && (
					<p class="mt-7 rounded-2xl border border-red-200 bg-red-50 p-4 text-red-900" role="alert">{lifecycleError}</p>
				)}
				{lifecycleCacheWarning && (
					<div class="mt-7 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-amber-950" role="alert">
						<p>Post #{lifecycleCacheWarning.postId} changed status, but its cached copies could not be cleared.</p>
						<form method="POST" action={lifecycleCacheWarning.status === 'hidden' ? actions.postLifecycle.hide : actions.postLifecycle.restore} class="mt-3">
							<input type="hidden" name="postId" value={lifecycleCacheWarning.postId} />
							<button type="submit" class="rounded-xl border border-amber-400 bg-white px-4 py-2 text-sm font-semibold hover:bg-amber-100">Retry cache purge</button>
						</form>
					</div>
				)}
				{deletionSuccess && (
					<p class="mt-7 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900" role="status">{deletionSuccess}</p>
				)}
				{deletionError && (
					<p class="mt-7 rounded-2xl border border-red-200 bg-red-50 p-4 text-red-900" role="alert">{deletionError}</p>
				)}
				{deletionWarning && (
					<div class="mt-7 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-amber-950" role="alert">
						<p>Post #{deletionWarning.postId} is hidden and awaiting cleanup. {deletionPhaseMessage[deletionWarning.phase]}</p>
						<form method="POST" action={actions.postDeletion.delete} class="mt-3">
							<input type="hidden" name="postId" value={deletionWarning.postId} />
							<input type="hidden" name="confirmation" value="delete" />
							<button type="submit" class="rounded-xl border border-amber-400 bg-white px-4 py-2 text-sm font-semibold hover:bg-amber-100">Retry permanent deletion</button>
						</form>
					</div>
				)}

				{posts.length === 0 ? (
					<p class="mt-8 rounded-3xl border border-dashed border-stone-300 bg-white p-8 text-center text-stone-600">There are no posts to moderate.</p>
				) : (
					<ol class="mt-8 space-y-5">
						{posts.map((post) => (
							<li class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm sm:p-7">
								<div class="flex flex-wrap items-start justify-between gap-4">
									<div>
										{post.status === 'deleting' ? (
											<p class="font-semibold text-stone-700">Post #{post.id}</p>
										) : (
											<a href={`/posts/${post.id}`} class="font-semibold text-rosewood hover:text-rose-800">Post #{post.id}</a>
										)}
										<p class="mt-1 text-sm text-stone-500">
											@{post.authorUsername} · {formatDateTime(post.createdAt)} UTC · {post.visibility} · {post.attachmentCount} {post.attachmentCount === 1 ? 'attachment' : 'attachments'}
										</p>
									</div>
									<span class:list={[
										'rounded-full px-3 py-1 text-xs font-semibold tracking-wide uppercase',
										post.status === 'active' ? 'bg-emerald-50 text-emerald-800' :
											post.status === 'hidden' ? 'bg-amber-100 text-amber-900' : 'bg-stone-200 text-stone-700',
									]}>{post.status}</span>
								</div>

								<div class="mt-5 rounded-2xl bg-stone-50 p-4 leading-7 text-stone-800">
									{post.body.trim() ? <PostBody body={post.body} /> : <p class="italic text-stone-500">Media-only post</p>}
								</div>

								<div class="mt-5 flex flex-wrap items-start gap-3">
									{post.status === 'deleting' ? (
										<form method="POST" action={actions.postDeletion.delete}>
											<input type="hidden" name="postId" value={post.id} />
											<input type="hidden" name="confirmation" value="delete" />
											<button type="submit" class="rounded-xl border border-amber-400 bg-amber-50 px-4 py-2 text-sm font-semibold text-amber-950 hover:bg-amber-100">Retry permanent deletion</button>
										</form>
									) : (
										<>
											<form method="POST" action={post.status === 'hidden' ? actions.postLifecycle.restore : actions.postLifecycle.hide}>
												<input type="hidden" name="postId" value={post.id} />
												<button type="submit" class="rounded-xl border border-stone-300 px-4 py-2 text-sm font-semibold text-stone-800 hover:border-stone-400 hover:bg-stone-50">{post.status === 'hidden' ? 'Restore post' : 'Hide post'}</button>
											</form>
											<details class="rounded-xl border border-red-200 bg-red-50 px-4 py-2 text-sm text-red-900">
												<summary class="cursor-pointer font-semibold">Permanently delete</summary>
												<form method="POST" action={actions.postDeletion.delete} class="mt-3 space-y-3">
													<input type="hidden" name="postId" value={post.id} />
													<label class="flex items-start gap-2">
														<input type="checkbox" name="confirmation" value="delete" required class="mt-1" />
														<span>This removes the post and its original media. It cannot be undone.</span>
													</label>
													<button type="submit" class="rounded-lg bg-red-700 px-3 py-2 font-semibold text-white hover:bg-red-800">Delete post</button>
												</form>
											</details>
										</>
									)}
								</div>
							</li>
						))}
					</ol>
				)}
			</>
		)}
	</main>
</BaseLayout>
