---
import PostBody from '../../components/PostBody.astro';
import { listModeratablePosts, MODERATABLE_POST_LIMIT } from '../../db/post-moderation-queries';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isOwner } from '../../lib/authorization';

Astro.cache.set(false);
Astro.response.headers.set('Cache-Control', 'private, no-store');
Astro.response.headers.set('Pragma', 'no-cache');

if (!Astro.locals.user) {
	return Astro.redirect('/login');
}

const owner = isOwner(Astro.locals.user);
if (!owner) Astro.response.status = 403;

const posts = owner ? await listModeratablePosts(Astro.locals.database) : [];
const formatDateTime = (date: Date) => new Intl.DateTimeFormat('en-US', {
	dateStyle: 'medium',
	timeStyle: 'short',
	timeZone: 'UTC',
}).format(date);
---

<BaseLayout title="Moderate posts · LoveNote">
	<header class="border-b border-stone-200 bg-white">
		<div class="mx-auto flex w-full max-w-4xl items-center justify-between px-5 py-4 sm:px-8">
			<a href="/" class="font-semibold tracking-tight text-stone-950">LoveNote</a>
			<nav class="flex items-center gap-4 text-sm" aria-label="Owner navigation">
				<a href="/owner/comments" class="text-stone-600 hover:text-stone-950">Comments</a>
				<a href="/owner/users" class="text-stone-600 hover:text-stone-950">Members</a>
				<a href="/account" class="text-stone-600 hover:text-stone-950">Account</a>
			</nav>
		</div>
	</header>

	<main class="mx-auto w-full max-w-4xl px-5 py-10 sm:px-8">
		<p class="text-sm font-semibold tracking-[0.16em] text-rosewood uppercase">Owner moderation</p>
		<h1 class="mt-2 text-3xl font-semibold tracking-tight text-stone-950">Posts</h1>

		{!owner ? (
			<p class="mt-7 rounded-2xl border border-red-200 bg-red-50 p-5 text-red-900" role="alert">Only the owner can moderate every post.</p>
		) : (
			<>
				<p class="mt-3 text-stone-600">Review the {MODERATABLE_POST_LIMIT} newest posts across all authors, visibility settings, and cleanup states.</p>

				{posts.length === 0 ? (
					<p class="mt-8 rounded-3xl border border-dashed border-stone-300 bg-white p-8 text-center text-stone-600">There are no posts to moderate.</p>
				) : (
					<ol class="mt-8 space-y-5">
						{posts.map((post) => (
							<li class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm sm:p-7">
								<div class="flex flex-wrap items-start justify-between gap-4">
									<div>
										{post.status === 'deleting' ? (
											<p class="font-semibold text-stone-700">Post #{post.id}</p>
										) : (
											<a href={`/posts/${post.id}`} class="font-semibold text-rosewood hover:text-rose-800">Post #{post.id}</a>
										)}
										<p class="mt-1 text-sm text-stone-500">
											@{post.authorUsername} · {formatDateTime(post.createdAt)} UTC · {post.visibility} · {post.attachmentCount} {post.attachmentCount === 1 ? 'attachment' : 'attachments'}
										</p>
									</div>
									<span class:list={[
										'rounded-full px-3 py-1 text-xs font-semibold tracking-wide uppercase',
										post.status === 'active' ? 'bg-emerald-50 text-emerald-800' :
											post.status === 'hidden' ? 'bg-amber-100 text-amber-900' : 'bg-stone-200 text-stone-700',
									]}>{post.status}</span>
								</div>

								<div class="mt-5 rounded-2xl bg-stone-50 p-4 leading-7 text-stone-800">
									{post.body.trim() ? <PostBody body={post.body} /> : <p class="italic text-stone-500">Media-only post</p>}
								</div>

								{post.status === 'deleting' && (
									<p class="mt-5 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-950">Deletion is incomplete and needs a cleanup retry.</p>
								)}
							</li>
						))}
					</ol>
				)}
			</>
		)}
	</main>
</BaseLayout>
