---
import { actions, isInputError } from 'astro:actions';

import PostBody from '../../components/PostBody.astro';
import { listModeratableComments } from '../../db/comment-moderation-queries';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { hasCapability, isOwner } from '../../lib/authorization';

Astro.cache.set(false);
Astro.response.headers.set('Cache-Control', 'private, no-store');
Astro.response.headers.set('Pragma', 'no-cache');

if (!Astro.locals.user) {
	return Astro.redirect('/login');
}

const canModerateComments = hasCapability(Astro.locals, 'moderateComments');
if (!canModerateComments) Astro.response.status = 403;

const hideResult = Astro.getActionResult(actions.comments.hide);
const restoreResult = Astro.getActionResult(actions.comments.restore);
const deletionResult = Astro.getActionResult(actions.comments.delete);
const purgeResult = Astro.getActionResult(actions.comments.retryPurge);
const result = hideResult ?? restoreResult ?? deletionResult ?? purgeResult;
const comments = canModerateComments
	? await listModeratableComments(Astro.locals.database, Astro.locals.user)
	: [];
const success = result?.data?.cachePurged
	? result.data.operation === 'purged'
		? `Cached copies of post #${result.data.postId} were cleared.`
		: `Comment #${result.data.commentId} was ${result.data.operation}.`
	: null;
const cacheWarning = result?.data?.cachePurged === false ? result.data : null;
const error = result?.error
	? isInputError(result.error)
		? 'The moderation request was invalid. Confirm permanent deletion when required.'
		: result.error.message
	: null;
const formatDateTime = (date: Date) => new Intl.DateTimeFormat('en-US', {
	dateStyle: 'medium',
	timeStyle: 'short',
	timeZone: 'UTC',
}).format(date);
---

<BaseLayout title="Moderate comments · LoveNote">
	<header class="border-b border-stone-200 bg-white">
		<div class="mx-auto flex w-full max-w-4xl items-center justify-between px-5 py-4 sm:px-8">
			<a href="/" class="font-semibold tracking-tight text-stone-950">LoveNote</a>
			<nav class="flex items-center gap-4 text-sm" aria-label="Member navigation">
				<a href="/manage" class="text-stone-600 hover:text-stone-950">Author tools</a>
				{Astro.locals.user && isOwner(Astro.locals.user) && <a href="/owner/posts" class="text-stone-600 hover:text-stone-950">Posts</a>}
				<a href="/account" class="text-stone-600 hover:text-stone-950">Account</a>
			</nav>
		</div>
	</header>

	<main class="mx-auto w-full max-w-4xl px-5 py-10 sm:px-8">
		<p class="text-sm font-semibold tracking-[0.16em] text-rosewood uppercase">Moderation</p>
		<h1 class="mt-2 text-3xl font-semibold tracking-tight text-stone-950">Comments</h1>

		{!canModerateComments ? (
			<div class="mt-7 rounded-2xl border border-red-200 bg-red-50 p-5 text-red-900" role="alert">
				You do not have permission to moderate comments.
			</div>
		) : (
			<>
				<p class="mt-3 text-stone-600">Review the 100 newest comments. Hidden comments remain visible here until permanently deleted.</p>

				{success && (
					<p class="mt-7 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900" role="status">{success}</p>
				)}
				{error && (
					<p class="mt-7 rounded-2xl border border-red-200 bg-red-50 p-4 text-red-900" role="alert">{error}</p>
				)}
				{cacheWarning && (
					<div class="mt-7 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-amber-950" role="alert">
						<p>The comment changed, but cached copies of post #{cacheWarning.postId} could not be cleared.</p>
						<form method="POST" action={actions.comments.retryPurge} class="mt-3">
							<input type="hidden" name="postId" value={cacheWarning.postId} />
							<button type="submit" class="rounded-xl border border-amber-400 bg-white px-4 py-2 text-sm font-semibold hover:bg-amber-100">Retry cache purge</button>
						</form>
					</div>
				)}

				{comments.length === 0 ? (
					<p class="mt-8 rounded-3xl border border-dashed border-stone-300 bg-white p-8 text-center text-stone-600">There are no comments to moderate.</p>
				) : (
					<ol class="mt-8 space-y-5">
						{comments.map((comment) => (
							<li class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm sm:p-7">
								<div class="flex flex-wrap items-start justify-between gap-4">
									<div>
										<p class="font-semibold text-stone-950">@{comment.authorUsername}</p>
										<p class="mt-1 text-sm text-stone-500">
											{formatDateTime(comment.createdAt)} UTC · <a href={`/posts/${comment.postId}`} class="font-medium text-rosewood hover:text-rose-800">Post #{comment.postId}</a> · {comment.postVisibility}
										</p>
									</div>
									<span class:list={[
										'rounded-full px-3 py-1 text-xs font-semibold tracking-wide uppercase',
										comment.status === 'visible' ? 'bg-emerald-50 text-emerald-800' : 'bg-amber-100 text-amber-900',
									]}>{comment.status}</span>
								</div>

								<div class="mt-5 rounded-2xl bg-stone-50 p-4 leading-7 text-stone-800">
									<PostBody body={comment.body} />
								</div>

								<div class="mt-5 flex flex-wrap items-start gap-3">
									<form method="POST" action={comment.status === 'visible' ? actions.comments.hide : actions.comments.restore}>
										<input type="hidden" name="commentId" value={comment.id} />
										<button type="submit" class="rounded-xl border border-stone-300 px-4 py-2 text-sm font-semibold text-stone-800 hover:border-stone-400 hover:bg-stone-50">
											{comment.status === 'visible' ? 'Hide comment' : 'Restore comment'}
										</button>
									</form>

									<details class="rounded-xl border border-red-200 bg-red-50 px-4 py-2 text-sm text-red-900">
										<summary class="cursor-pointer font-semibold">Permanently delete</summary>
										<form method="POST" action={actions.comments.delete} class="mt-3 space-y-3">
											<input type="hidden" name="commentId" value={comment.id} />
											<label class="flex items-start gap-2">
												<input type="checkbox" name="confirmation" value="delete" required class="mt-1" />
												<span>This cannot be undone.</span>
											</label>
											<button type="submit" class="rounded-lg bg-red-700 px-3 py-2 font-semibold text-white hover:bg-red-800">Delete comment</button>
										</form>
									</details>
								</div>
							</li>
						))}
					</ol>
				)}
			</>
		)}
	</main>
</BaseLayout>
