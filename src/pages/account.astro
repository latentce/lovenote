---
import { actions, isInputError } from 'astro:actions';

import LogoutButton from '../components/LogoutButton.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { isOwner } from '../lib/authorization';

Astro.cache.set(false);
Astro.response.headers.set('Cache-Control', 'private, no-store');
Astro.response.headers.set('Pragma', 'no-cache');

if (!Astro.locals.user) {
	return Astro.redirect('/login');
}

const result = Astro.getActionResult(actions.account.changePassword);
const inputErrors = isInputError(result?.error) ? result.error.fields : {};
const displayName =
	Astro.locals.user.displayUsername ?? Astro.locals.user.username ?? Astro.locals.user.name;
const mustChangePassword = Astro.locals.permissions?.temporaryPassword === true;
---

<BaseLayout title="Your account · LoveNote">
	<header class="border-b border-stone-200 bg-white">
		<div class="mx-auto flex w-full max-w-3xl items-center justify-between px-5 py-4 sm:px-8">
			<a href="/" class="font-semibold tracking-tight text-stone-950">LoveNote</a>
			<LogoutButton />
		</div>
	</header>

	<main class="mx-auto w-full max-w-3xl px-5 py-10 sm:px-8">
		<p class="text-sm font-semibold tracking-[0.16em] text-rosewood uppercase">Account</p>
		<h1 class="mt-2 text-3xl font-semibold tracking-tight text-stone-950">{displayName}</h1>
		<p class="mt-2 text-stone-600">{isOwner(Astro.locals.user) ? 'Owner' : 'Member'}</p>

		{mustChangePassword && !result?.data?.changed && (
			<div class="mt-8 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-amber-950" role="status">
				Change your temporary password before creating or interacting with content.
			</div>
		)}

		<section class="mt-8 rounded-3xl border border-stone-200 bg-white p-7 shadow-sm sm:p-9">
			<h2 class="text-xl font-semibold text-stone-950">Change password</h2>
			<p class="mt-2 text-sm text-stone-600">Use 12–128 characters and choose a password you do not use elsewhere.</p>

			{result?.data?.changed && (
				<div class="mt-6 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900" role="status">
					Your password has been changed.
				</div>
			)}

			{result?.error && !isInputError(result.error) && (
				<div class="mt-6 rounded-2xl border border-red-200 bg-red-50 p-4 text-red-900" role="alert">
					{result.error.message}
				</div>
			)}

			<form method="POST" action={actions.account.changePassword} class="mt-7 space-y-5">
				<label class="block">
					<span class="text-sm font-medium text-stone-800">Current password</span>
					<input
						type="password"
						name="currentPassword"
						required
						maxlength="128"
						autocomplete="current-password"
						aria-describedby={inputErrors.currentPassword ? 'current-password-error' : undefined}
						class="mt-2 w-full rounded-xl border border-stone-300 bg-white px-4 py-3 outline-none focus:border-rosewood focus:ring-2 focus:ring-rose-100"
					/>
					{inputErrors.currentPassword && <span id="current-password-error" class="mt-1 block text-sm text-red-700">{inputErrors.currentPassword.join(' ')}</span>}
				</label>

				<label class="block">
					<span class="text-sm font-medium text-stone-800">New password</span>
					<input
						type="password"
						name="newPassword"
						required
						minlength="12"
						maxlength="128"
						autocomplete="new-password"
						aria-describedby={inputErrors.newPassword ? 'new-password-error' : undefined}
						class="mt-2 w-full rounded-xl border border-stone-300 bg-white px-4 py-3 outline-none focus:border-rosewood focus:ring-2 focus:ring-rose-100"
					/>
					{inputErrors.newPassword && <span id="new-password-error" class="mt-1 block text-sm text-red-700">{inputErrors.newPassword.join(' ')}</span>}
				</label>

				<label class="block">
					<span class="text-sm font-medium text-stone-800">Confirm new password</span>
					<input
						type="password"
						name="confirmPassword"
						required
						minlength="12"
						maxlength="128"
						autocomplete="new-password"
						aria-describedby={inputErrors.confirmPassword ? 'confirm-password-error' : undefined}
						class="mt-2 w-full rounded-xl border border-stone-300 bg-white px-4 py-3 outline-none focus:border-rosewood focus:ring-2 focus:ring-rose-100"
					/>
					{inputErrors.confirmPassword && <span id="confirm-password-error" class="mt-1 block text-sm text-red-700">{inputErrors.confirmPassword.join(' ')}</span>}
				</label>

				<button type="submit" class="rounded-xl bg-rosewood px-5 py-3 font-semibold text-white transition hover:bg-rose-800 focus:outline-none focus:ring-2 focus:ring-rose-300 focus:ring-offset-2">
					Change password
				</button>
			</form>
		</section>
	</main>
</BaseLayout>
