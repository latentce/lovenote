---
import { actions, isInputError } from 'astro:actions';

import CommentComposer from '../../components/CommentComposer.astro';
import CommentControls from '../../components/CommentControls.astro';
import PostBody from '../../components/PostBody.astro';
import PostCard from '../../components/PostCard.astro';
import { findPostDetail } from '../../db/post-queries';
import BaseLayout from '../../layouts/BaseLayout.astro';

const idValue = Astro.params.id ?? '';
const postId = /^[1-9]\d*$/.test(idValue) ? Number(idValue) : Number.NaN;
const post = Number.isSafeInteger(postId)
	? await findPostDetail(Astro.locals.database, postId, Astro.locals.user)
	: null;

const isCacheablePublicPost = post?.status === 'active' && post.visibility === 'public';

if (!post) {
	Astro.response.status = 404;
	Astro.response.statusText = 'Not Found';
}

if (!isCacheablePublicPost) {
	Astro.cache.set(false);
	Astro.response.headers.set('Cache-Control', 'private, no-store');
} else if (Astro.cache.enabled) {
	Astro.cache.set({ tags: [`post:${post.id}`] });
}

const pageTitle = post ? `Post by ${post.authorUsername} · LoveNote` : 'Post not found · LoveNote';
const pageDescription = post?.body.trim().replace(/\s+/g, ' ').slice(0, 160) ||
	(post ? 'A shared photo or video on LoveNote.' : 'This LoveNote post is not available.');
const commentResult = Astro.getActionResult(actions.comments.create);
const commentInputErrors = isInputError(commentResult?.error) ? commentResult.error.fields : {};
const commentSuccess = Boolean(
	post && commentResult?.data?.commentId && commentResult.data.postId === post.id,
);
const commentError = commentResult?.error && !isInputError(commentResult.error)
	? commentResult.error.message
	: null;
const formatDate = (date: Date) => new Intl.DateTimeFormat('en-US', {
	dateStyle: 'medium',
	timeStyle: 'short',
	timeZone: 'UTC',
}).format(date);
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<header class="border-b border-stone-200 bg-white">
		<div class="mx-auto flex w-full max-w-3xl items-center justify-between px-5 py-4 sm:px-8">
			<a href="/" class="font-semibold tracking-tight text-stone-950">LoveNote</a>
			<a href="/login" class="text-sm font-medium text-rosewood hover:text-rose-800">Member sign in</a>
		</div>
	</header>

	<main class="mx-auto w-full max-w-3xl px-5 py-10 sm:px-8 sm:py-14">
		{post ? (
			<>
				<div class="mb-5 flex flex-wrap items-center justify-between gap-3">
					<a href="/" class="text-sm font-semibold text-rosewood hover:text-rose-800">← Public feed</a>
					{post.visibility === 'private' && (
						<span class="rounded-full bg-stone-200 px-3 py-1 text-xs font-semibold tracking-wide text-stone-700 uppercase">Private</span>
					)}
					{post.status === 'hidden' && (
						<span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold tracking-wide text-amber-900 uppercase">Hidden</span>
					)}
				</div>

				<PostCard post={post} eagerFirstMedia />

				<section class="mt-8 rounded-3xl border border-stone-200 bg-white px-5 py-6 shadow-sm sm:px-7" aria-labelledby="post-details-heading">
					<h1 id="post-details-heading" class="text-lg font-semibold text-stone-950">Post details</h1>
					<p class="mt-2 text-sm text-stone-600">
						{post.favoriteCount} {post.favoriteCount === 1 ? 'favorite' : 'favorites'}
					</p>

					{post.tags.length > 0 && (
						<ul class="mt-5 flex flex-wrap gap-2" aria-label="Tags">
							{post.tags.map((tag) => (
								<li><a href={`/tags/${encodeURIComponent(tag.slug)}`} class="rounded-full bg-rose-50 px-3 py-1 text-sm font-medium text-rosewood hover:bg-rose-100">#{tag.displayName}</a></li>
							))}
						</ul>
					)}
				</section>

				<section class="mt-8" aria-labelledby="comments-heading">
					<div class="flex items-baseline justify-between gap-4">
						<h2 id="comments-heading" class="text-2xl font-semibold tracking-tight text-stone-950">Comments</h2>
						<p class="text-sm text-stone-500">{post.comments.length} visible</p>
					</div>

					<div class="mt-5">
						<CommentControls
							server:defer
							postId={post.id}
							bodyErrors={commentInputErrors.body}
							errorMessage={commentError}
							success={commentSuccess}
						>
							<div slot="fallback">
								<CommentComposer
									postId={post.id}
									bodyErrors={commentInputErrors.body}
									errorMessage={commentError}
									success={commentSuccess}
								/>
							</div>
						</CommentControls>
					</div>

					{post.comments.length === 0 ? (
						<p class="mt-5 rounded-3xl border border-dashed border-stone-300 bg-white p-7 text-center text-stone-600">No comments yet.</p>
					) : (
						<ol class="mt-5 space-y-4">
							{post.comments.map((comment) => (
								<li class="rounded-3xl border border-stone-200 bg-white px-5 py-5 shadow-sm sm:px-7">
									<header class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
										<p class="font-semibold text-stone-950">{comment.authorUsername}</p>
										<time datetime={comment.createdAt.toISOString()} class="text-sm text-stone-500">{formatDate(comment.createdAt)}</time>
									</header>
									<div class="mt-3 leading-7 text-stone-800"><PostBody body={comment.body} /></div>
								</li>
							))}
						</ol>
					)}
				</section>
			</>
		) : (
			<section class="rounded-3xl border border-stone-200 bg-white p-10 text-center shadow-sm">
				<p class="text-sm font-semibold tracking-[0.16em] text-rosewood uppercase">404</p>
				<h1 class="mt-2 text-3xl font-semibold tracking-tight text-stone-950">Post not found</h1>
				<p class="mt-3 text-stone-600">This post does not exist, or it is not available to you.</p>
				<a href="/" class="mt-6 inline-block font-semibold text-rosewood hover:text-rose-800">Return to the public feed</a>
			</section>
		)}
	</main>
</BaseLayout>
