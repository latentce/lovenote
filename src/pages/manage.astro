---
import { actions, isInputError } from 'astro:actions';

import { listOwnPosts } from '../db/post-queries';
import BaseLayout from '../layouts/BaseLayout.astro';
import { hasCapability } from '../lib/authorization';
import {
	IMAGE_UPLOAD_LIMIT,
	SUPPORTED_MEDIA_TYPES,
	VIDEO_UPLOAD_LIMIT,
} from '../lib/media';
import { MAX_POST_ATTACHMENTS, MAX_POST_BODY_LENGTH } from '../lib/post';

Astro.cache.set(false);
Astro.response.headers.set('Cache-Control', 'private, no-store');
Astro.response.headers.set('Pragma', 'no-cache');

if (!Astro.locals.user) {
	return Astro.redirect('/login');
}

const result = Astro.getActionResult(actions.posts.create);
const hideResult = Astro.getActionResult(actions.postLifecycle.hide);
const restoreResult = Astro.getActionResult(actions.postLifecycle.restore);
const deletionResult = Astro.getActionResult(actions.postDeletion.delete);
const lifecycleResult = hideResult ?? restoreResult;
const inputErrors = isInputError(result?.error) ? result.error.fields : {};
const canCreatePosts = hasCapability(Astro.locals, 'createPosts');
const canDeleteOwnPosts = hasCapability(Astro.locals, 'deleteOwnPosts');
const canEditOwnPosts = hasCapability(Astro.locals, 'editOwnPosts');
const canHideOwnPosts = hasCapability(Astro.locals, 'hideOwnPosts');
const canUploadImages = hasCapability(Astro.locals, 'uploadImages');
const canUploadVideos = hasCapability(Astro.locals, 'uploadVideos');
const allowedMediaTypes = SUPPORTED_MEDIA_TYPES.filter((mimeType) =>
	mimeType.startsWith('image/') ? canUploadImages : canUploadVideos,
);
const canUploadMedia = allowedMediaTypes.length > 0;
const allowedMediaLabel = canUploadImages && canUploadVideos
	? 'images or videos'
	: canUploadImages
		? 'images'
		: 'videos';
const ownPosts = await listOwnPosts(Astro.locals.database, Astro.locals.user.id);
const lifecycleSuccess = lifecycleResult?.data?.cachePurged
	? `Post #${lifecycleResult.data.postId} is now ${lifecycleResult.data.status}.`
	: null;
const lifecycleCacheWarning = lifecycleResult?.data?.cachePurged === false
	? lifecycleResult.data
	: null;
const lifecycleError = lifecycleResult?.error
	? isInputError(lifecycleResult.error)
		? 'The post request was invalid.'
		: lifecycleResult.error.message
	: null;
const deletionSuccess = deletionResult?.data?.completed
	? `Post #${deletionResult.data.postId} was permanently deleted.`
	: null;
const deletionWarning = deletionResult?.data?.completed === false
	? deletionResult.data
	: null;
const deletionError = deletionResult?.error
	? isInputError(deletionResult.error)
		? 'Confirm permanent deletion before continuing.'
		: deletionResult.error.message
	: null;
const deletionPhaseMessage = {
	cache: 'Its cached copies could not be cleared.',
	database: 'Its database record could not be finalized.',
	storage: 'One or more media files could not be removed from storage.',
} as const;
const formatDate = (date: Date) => new Intl.DateTimeFormat('en-US', {
	dateStyle: 'medium',
	timeZone: 'UTC',
}).format(date);
---

<BaseLayout title="Manage posts · LoveNote">
	<header class="border-b border-stone-200 bg-white">
		<div class="mx-auto flex w-full max-w-3xl items-center justify-between px-5 py-4 sm:px-8">
			<a href="/" class="font-semibold tracking-tight text-stone-950">LoveNote</a>
			<nav class="flex items-center gap-4 text-sm" aria-label="Member navigation">
				<a href="/private" class="text-stone-600 hover:text-stone-950">Private feed</a>
				<a href="/account" class="text-stone-600 hover:text-stone-950">Account</a>
			</nav>
		</div>
	</header>

	<main class="mx-auto w-full max-w-3xl px-5 py-10 sm:px-8">
		<p class="text-sm font-semibold tracking-[0.16em] text-rosewood uppercase">Author tools</p>
		<h1 class="mt-2 text-3xl font-semibold tracking-tight text-stone-950">Create a post</h1>
		<p class="mt-3 text-stone-600">Write up to {MAX_POST_BODY_LENGTH.toLocaleString()} characters and optionally attach {MAX_POST_ATTACHMENTS} original {allowedMediaLabel}.</p>

		{result?.data?.postId && (
			<div class="mt-7 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900" role="status">
				Post #{result.data.postId} was created.
			</div>
		)}

		{result?.error && !isInputError(result.error) && (
			<div class="mt-7 rounded-2xl border border-red-200 bg-red-50 p-4 text-red-900" role="alert">
				{result.error.message}
			</div>
		)}

		{!canCreatePosts ? (
			<div class="mt-8 rounded-2xl border border-amber-200 bg-amber-50 p-5 text-amber-950">
				You cannot create posts with the current account permissions. If you still have a temporary password,
				<a href="/account" class="font-semibold underline">change it from your account page</a>.
			</div>
		) : (
			<form id="post-composer" method="POST" action={actions.posts.create} class="mt-8 space-y-7 rounded-3xl border border-stone-200 bg-white p-6 shadow-sm sm:p-9">
				<label class="block">
					<span class="text-sm font-medium text-stone-800">Post text</span>
					<textarea
						name="body"
						rows="9"
						maxlength={MAX_POST_BODY_LENGTH}
						aria-describedby={inputErrors.body ? 'post-body-error' : 'post-body-help'}
						class="mt-2 w-full resize-y rounded-xl border border-stone-300 bg-white px-4 py-3 leading-7 outline-none focus:border-rosewood focus:ring-2 focus:ring-rose-100"
					></textarea>
					<span id="post-body-help" class="mt-1 block text-sm text-stone-500">Plain text only. HTTP and HTTPS links will become clickable.</span>
					{inputErrors.body && <span id="post-body-error" class="mt-1 block text-sm text-red-700">{inputErrors.body.join(' ')}</span>}
				</label>

				{canUploadMedia && (
					<fieldset
						id="media-uploader"
						class="rounded-2xl border border-stone-200 bg-stone-50 p-5"
						data-image-limit={IMAGE_UPLOAD_LIMIT}
						data-max-attachments={MAX_POST_ATTACHMENTS}
						data-video-limit={VIDEO_UPLOAD_LIMIT}
						data-types={JSON.stringify(allowedMediaTypes)}
					>
						<legend class="px-2 text-sm font-semibold text-stone-900">Attachments</legend>
						<label class="block">
							<span class="text-sm text-stone-700">Choose up to {MAX_POST_ATTACHMENTS} {allowedMediaLabel}</span>
							<input
								id="media-files"
								type="file"
								multiple
								accept={allowedMediaTypes.join(',')}
								class="mt-2 block w-full text-sm text-stone-700 file:mr-4 file:rounded-lg file:border-0 file:bg-stone-200 file:px-4 file:py-2 file:font-medium file:text-stone-900 hover:file:bg-stone-300"
							/>
						</label>
						<p class="mt-2 text-xs text-stone-500">
							{canUploadImages && <>Images: 50 MB maximum. </>}
							{canUploadVideos && <>Videos: 250 MB maximum. </>}
							Originals and embedded metadata are preserved.
						</p>

						<div id="upload-message" class="mt-4 hidden rounded-xl p-3 text-sm" role="status" aria-live="polite"></div>
						<ol id="upload-list" class="mt-4 space-y-3"></ol>
						<div class="mt-4 flex flex-wrap gap-3">
							<button id="upload-media" type="button" disabled class="rounded-xl bg-stone-900 px-4 py-2 text-sm font-semibold text-white disabled:cursor-not-allowed disabled:opacity-40">
								Upload selected files
							</button>
							<button id="clear-media" type="button" disabled class="rounded-xl border border-stone-300 bg-white px-4 py-2 text-sm font-semibold text-stone-800 disabled:cursor-not-allowed disabled:opacity-40">
								Clear selection
							</button>
						</div>
						<noscript><p class="mt-4 text-sm text-amber-800">Media uploads require JavaScript. Text-only posts still work without it.</p></noscript>
					</fieldset>
				)}

				<label class="block">
					<span class="text-sm font-medium text-stone-800">Visibility</span>
					<select name="visibility" class="mt-2 w-full rounded-xl border border-stone-300 bg-white px-4 py-3 outline-none focus:border-rosewood focus:ring-2 focus:ring-rose-100">
						<option value="private" selected>Private — all active members</option>
						<option value="public">Public — anyone</option>
					</select>
					{inputErrors.visibility && <span class="mt-1 block text-sm text-red-700">{inputErrors.visibility.join(' ')}</span>}
				</label>

				{inputErrors.attachmentIds && <p class="text-sm text-red-700">{inputErrors.attachmentIds.join(' ')}</p>}

				<button id="publish-post" type="submit" class="rounded-xl bg-rosewood px-5 py-3 font-semibold text-white transition hover:bg-rose-800 focus:outline-none focus:ring-2 focus:ring-rose-300 focus:ring-offset-2">
					Publish post
				</button>
			</form>
		)}

		<section class="mt-14 border-t border-stone-200 pt-10" aria-labelledby="your-posts-heading">
			<p class="text-sm font-semibold tracking-[0.16em] text-rosewood uppercase">Published by you</p>
			<h2 id="your-posts-heading" class="mt-2 text-3xl font-semibold tracking-tight text-stone-950">Your posts</h2>
			<p class="mt-3 text-stone-600">Your 50 most recent posts, including posts hidden from everyone except you and the owner.</p>

			{lifecycleSuccess && (
				<p class="mt-6 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900" role="status">{lifecycleSuccess}</p>
			)}
			{lifecycleError && (
				<p class="mt-6 rounded-2xl border border-red-200 bg-red-50 p-4 text-red-900" role="alert">{lifecycleError}</p>
			)}
			{lifecycleCacheWarning && (
				<div class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-amber-950" role="alert">
					<p>Post #{lifecycleCacheWarning.postId} changed status, but its cached copies could not be cleared.</p>
					<form
						method="POST"
						action={lifecycleCacheWarning.status === 'hidden' ? actions.postLifecycle.hide : actions.postLifecycle.restore}
						class="mt-3"
					>
						<input type="hidden" name="postId" value={lifecycleCacheWarning.postId} />
						<button type="submit" class="rounded-xl border border-amber-400 bg-white px-4 py-2 text-sm font-semibold hover:bg-amber-100">Retry cache purge</button>
					</form>
				</div>
			)}
			{deletionSuccess && (
				<p class="mt-6 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900" role="status">{deletionSuccess}</p>
			)}
			{deletionError && (
				<p class="mt-6 rounded-2xl border border-red-200 bg-red-50 p-4 text-red-900" role="alert">{deletionError}</p>
			)}
			{deletionWarning && (
				<div class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-amber-950" role="alert">
					<p>Post #{deletionWarning.postId} is hidden and awaiting cleanup. {deletionPhaseMessage[deletionWarning.phase]}</p>
					<form method="POST" action={actions.postDeletion.delete} class="mt-3">
						<input type="hidden" name="postId" value={deletionWarning.postId} />
						<input type="hidden" name="confirmation" value="delete" />
						<button type="submit" class="rounded-xl border border-amber-400 bg-white px-4 py-2 text-sm font-semibold hover:bg-amber-100">Retry permanent deletion</button>
					</form>
				</div>
			)}

			{ownPosts.length === 0 ? (
				<p class="mt-7 rounded-3xl border border-dashed border-stone-300 bg-white p-8 text-center text-stone-600">You have not published any posts yet.</p>
			) : (
				<ol class="mt-7 space-y-4">
					{ownPosts.map((post) => (
						<li class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm sm:p-7">
							<div class="flex flex-wrap items-start justify-between gap-4">
								<div>
									{post.status === 'deleting' ? (
										<p class="font-semibold text-stone-700">Post #{post.id}</p>
									) : (
										<a href={`/posts/${post.id}`} class="font-semibold text-rosewood hover:text-rose-800">Post #{post.id}</a>
									)}
									<p class="mt-1 text-sm text-stone-500">{formatDate(post.createdAt)} · {post.visibility}</p>
								</div>
								<span class:list={[
									'rounded-full px-3 py-1 text-xs font-semibold tracking-wide uppercase',
									post.status === 'active' ? 'bg-emerald-50 text-emerald-800' :
										post.status === 'hidden' ? 'bg-amber-100 text-amber-900' : 'bg-stone-200 text-stone-700',
								]}>{post.status}</span>
							</div>

							<p class="mt-4 line-clamp-3 leading-7 text-stone-700">
								{post.body.trim().replace(/\s+/gu, ' ').slice(0, 240) || 'Media-only post'}
							</p>

							<div class="mt-5 flex flex-wrap items-start gap-3">
								{canEditOwnPosts && post.status !== 'deleting' && (
									<a href={`/manage/posts/${post.id}`} class="rounded-xl border border-stone-300 px-4 py-2 text-sm font-semibold text-stone-800 hover:border-stone-400 hover:bg-stone-50">Edit post</a>
								)}
								{canHideOwnPosts && post.status !== 'deleting' && (
									<form
										method="POST"
										action={post.status === 'hidden' ? actions.postLifecycle.restore : actions.postLifecycle.hide}
									>
										<input type="hidden" name="postId" value={post.id} />
										<button type="submit" class="rounded-xl border border-stone-300 px-4 py-2 text-sm font-semibold text-stone-800 hover:border-stone-400 hover:bg-stone-50">
											{post.status === 'hidden' ? 'Restore post' : 'Hide post'}
										</button>
									</form>
								)}

								{canDeleteOwnPosts && post.status === 'deleting' && (
									<form method="POST" action={actions.postDeletion.delete}>
										<input type="hidden" name="postId" value={post.id} />
										<input type="hidden" name="confirmation" value="delete" />
										<button type="submit" class="rounded-xl border border-amber-400 bg-amber-50 px-4 py-2 text-sm font-semibold text-amber-950 hover:bg-amber-100">Retry permanent deletion</button>
									</form>
								)}
							</div>

							{canDeleteOwnPosts && post.status !== 'deleting' && (
								<details class="mt-5 rounded-2xl border border-red-200 bg-red-50 p-4 text-red-950">
									<summary class="cursor-pointer text-sm font-semibold">Delete permanently</summary>
									<p class="mt-3 text-sm leading-6">This removes the post, comments, favorites, tag links, and original media files. It cannot be undone.</p>
									<form method="POST" action={actions.postDeletion.delete} class="mt-4">
										<input type="hidden" name="postId" value={post.id} />
										<label class="flex items-start gap-2 text-sm">
											<input type="checkbox" name="confirmation" value="delete" required class="mt-1" />
											<span>I understand this post and its original media files will be permanently deleted.</span>
										</label>
										<button type="submit" class="mt-4 rounded-xl bg-red-800 px-4 py-2 text-sm font-semibold text-white hover:bg-red-900">Delete post permanently</button>
									</form>
								</details>
							)}
						</li>
					))}
				</ol>
			)}
		</section>
	</main>
</BaseLayout>

<script>
	import { actions } from 'astro:actions';

	interface MediaMetadata {
		durationMs?: number;
		height: number;
		width: number;
	}

	interface UploadItem {
		altInput: HTMLInputElement;
		file: File;
		metadata: MediaMetadata;
		progress: HTMLProgressElement;
		status: 'pending' | 'uploading' | 'ready' | 'failed';
		statusText: HTMLSpanElement;
	}

	const composer = document.querySelector<HTMLFormElement>('#post-composer');
	const uploader = document.querySelector<HTMLFieldSetElement>('#media-uploader');
	const fileInput = document.querySelector<HTMLInputElement>('#media-files');
	const uploadButton = document.querySelector<HTMLButtonElement>('#upload-media');
	const clearButton = document.querySelector<HTMLButtonElement>('#clear-media');
	const uploadList = document.querySelector<HTMLOListElement>('#upload-list');
	const uploadMessage = document.querySelector<HTMLDivElement>('#upload-message');
	let uploadItems: UploadItem[] = [];
	let uploadStarted = false;

	function showMessage(message: string, error = false) {
		if (!uploadMessage) return;
		uploadMessage.textContent = message;
		uploadMessage.className = `mt-4 rounded-xl border p-3 text-sm ${error ? 'border-red-200 bg-red-50 text-red-900' : 'border-emerald-200 bg-emerald-50 text-emerald-900'}`;
	}

	function metadataFor(file: File): Promise<MediaMetadata> {
		return new Promise((resolve, reject) => {
			const objectUrl = URL.createObjectURL(file);
			const cleanUp = () => URL.revokeObjectURL(objectUrl);

			if (file.type.startsWith('image/')) {
				const image = new Image();
				image.onload = () => {
					const metadata = { height: image.naturalHeight, width: image.naturalWidth };
					cleanUp();
					metadata.height > 0 && metadata.width > 0
						? resolve(metadata)
						: reject(new Error('Image dimensions could not be read.'));
				};
				image.onerror = () => {
					cleanUp();
					reject(new Error('This image could not be decoded by your browser.'));
				};
				image.src = objectUrl;
				return;
			}

			const video = document.createElement('video');
			video.preload = 'metadata';
			video.muted = true;
			video.onloadedmetadata = () => {
				const metadata = {
					durationMs: Math.round(video.duration * 1000),
					height: video.videoHeight,
					width: video.videoWidth,
				};
				cleanUp();
				metadata.height > 0 && metadata.width > 0 && Number.isFinite(metadata.durationMs) && metadata.durationMs > 0
					? resolve(metadata)
					: reject(new Error('Video metadata could not be read.'));
			};
			video.onerror = () => {
				cleanUp();
				reject(new Error('This video or codec is not supported by your browser.'));
			};
			video.src = objectUrl;
		});
	}

	function renderItem(item: UploadItem) {
		if (!uploadList) return;
		const row = document.createElement('li');
		row.className = 'rounded-xl border border-stone-200 bg-white p-4';
		const heading = document.createElement('div');
		heading.className = 'flex items-start justify-between gap-3';
		const filename = document.createElement('span');
		filename.className = 'break-all text-sm font-medium text-stone-900';
		filename.textContent = item.file.name;
		item.statusText.className = 'shrink-0 text-xs text-stone-500';
		item.statusText.textContent = 'Ready to upload';
		heading.appendChild(filename);
		heading.appendChild(item.statusText);
		item.progress.className = 'mt-3 h-2 w-full';
		item.progress.max = 100;
		item.progress.value = 0;
		const label = document.createElement('label');
		label.className = 'mt-3 block text-xs font-medium text-stone-700';
		label.textContent = 'Alt text (optional)';
		item.altInput.maxLength = 1000;
		item.altInput.className = 'mt-1 w-full rounded-lg border border-stone-300 px-3 py-2 text-sm';
		label.appendChild(item.altInput);
		row.appendChild(heading);
		row.appendChild(item.progress);
		row.appendChild(label);
		uploadList.appendChild(row);
	}

	function uploadFile(item: UploadItem, uploadUrl: string, headers: Record<string, string>) {
		return new Promise<void>((resolve, reject) => {
			const request = new XMLHttpRequest();
			request.open('PUT', uploadUrl);
			for (const [name, value] of Object.entries(headers)) request.setRequestHeader(name, value);
			request.upload.addEventListener('progress', (event) => {
				if (event.lengthComputable) item.progress.value = Math.round((event.loaded / event.total) * 100);
			});
			request.addEventListener('load', () => {
				request.status >= 200 && request.status < 300
					? resolve()
					: reject(new Error(`R2 rejected the upload with status ${request.status}.`));
			});
			request.addEventListener('error', () => reject(new Error('The upload was interrupted.')));
			request.send(item.file);
		});
	}

	fileInput?.addEventListener('change', async () => {
		if (!uploader || !uploadList || !uploadButton || !clearButton || uploadStarted) return;
		uploadList.replaceChildren();
		uploadItems = [];
		const files = Array.from(fileInput.files ?? []);
		const parsedTypes: unknown = JSON.parse(uploader.dataset.types ?? '[]');
		const allowedTypes = Array.isArray(parsedTypes)
			? parsedTypes.filter((value): value is string => typeof value === 'string')
			: [];
		const imageLimit = Number(uploader.dataset.imageLimit);
		const maxAttachments = Number(uploader.dataset.maxAttachments);
		const videoLimit = Number(uploader.dataset.videoLimit);

		if (files.length > maxAttachments) {
			showMessage(`Choose no more than ${maxAttachments} files.`, true);
			fileInput.value = '';
			return;
		}

		try {
			for (const file of files) {
				if (!allowedTypes.includes(file.type)) throw new Error(`${file.name} has an unsupported file type.`);
				const limit = file.type.startsWith('image/') ? imageLimit : videoLimit;
				if (file.size <= 0 || file.size > limit) throw new Error(`${file.name} exceeds its upload limit.`);
				const item: UploadItem = {
					altInput: document.createElement('input'),
					file,
					metadata: await metadataFor(file),
					progress: document.createElement('progress'),
					status: 'pending',
					statusText: document.createElement('span'),
				};
				uploadItems.push(item);
				renderItem(item);
			}
			uploadButton.disabled = uploadItems.length === 0;
			clearButton.disabled = uploadItems.length === 0;
			if (uploadItems.length > 0) showMessage('Files validated. Add alt text, then upload them.');
		} catch (error) {
			uploadList.replaceChildren();
			uploadItems = [];
			fileInput.value = '';
			uploadButton.disabled = true;
			clearButton.disabled = true;
			showMessage(error instanceof Error ? error.message : 'The files could not be validated.', true);
		}
	});

	clearButton?.addEventListener('click', () => {
		if (!fileInput || !uploadList || !uploadButton || uploadStarted) return;
		fileInput.value = '';
		uploadList.replaceChildren();
		uploadItems = [];
		uploadButton.disabled = true;
		clearButton.disabled = true;
		showMessage('Selection cleared.');
	});

	uploadButton?.addEventListener('click', async () => {
		if (!fileInput || !uploadButton || !clearButton || uploadItems.length === 0) return;
		uploadStarted = true;
		fileInput.disabled = true;
		uploadButton.disabled = true;
		clearButton.disabled = true;

		try {
			for (const item of uploadItems) {
				if (item.status === 'ready') continue;
				item.status = 'uploading';
				item.statusText.textContent = 'Preparing';
				const requested = await actions.uploads.request({
					altText: item.altInput.value,
					byteSize: item.file.size,
					durationMs: item.metadata.durationMs ?? null,
					height: item.metadata.height,
					mimeType: item.file.type,
					originalFilename: item.file.name,
					width: item.metadata.width,
				});
				if (requested.error) throw new Error(requested.error.message);
				item.statusText.textContent = 'Uploading';
				await uploadFile(item, requested.data.uploadUrl, requested.data.headers);
				item.statusText.textContent = 'Verifying';
				const completed = await actions.uploads.complete({ assetId: requested.data.assetId });
				if (completed.error) throw new Error(completed.error.message);
				const attachment = document.createElement('input');
				attachment.type = 'hidden';
				attachment.name = 'attachmentIds';
				attachment.value = completed.data.assetId;
				composer?.appendChild(attachment);
				item.status = 'ready';
				item.progress.value = 100;
				item.statusText.textContent = 'Ready';
				item.altInput.disabled = true;
			}
			showMessage('All attachments are ready. You can publish the post.');
		} catch (error) {
			const activeItem = uploadItems.find((item) => item.status === 'uploading');
			if (activeItem) {
				activeItem.status = 'failed';
				activeItem.statusText.textContent = 'Failed';
			}
			uploadStarted = false;
			uploadButton.disabled = false;
			showMessage(error instanceof Error ? error.message : 'The upload failed.', true);
		}
	});

	composer?.addEventListener('submit', (event) => {
		if (uploadItems.some((item) => item.status !== 'ready')) {
			event.preventDefault();
			showMessage('Finish uploading every selected attachment before publishing.', true);
		}
	});
</script>
