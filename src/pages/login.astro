---
import BaseLayout from '../layouts/BaseLayout.astro';

Astro.cache.set(false);
Astro.response.headers.set('Cache-Control', 'private, no-store');
Astro.response.headers.set('Pragma', 'no-cache');

if (Astro.locals.user) {
	return Astro.redirect('/account');
}
---

<BaseLayout title="Sign in to LoveNote">
	<main class="mx-auto flex min-h-screen w-full max-w-xl items-center px-5 py-12 sm:px-8">
		<section class="w-full rounded-3xl border border-stone-200 bg-white p-7 shadow-sm sm:p-10">
			<p class="text-sm font-semibold tracking-[0.16em] text-rosewood uppercase">LoveNote</p>
			<h1 class="mt-3 text-3xl font-semibold tracking-tight text-stone-900">Sign in</h1>
			<p class="mt-3 text-stone-600">Use the username and password provided by the owner.</p>

			<p data-login-status class="mt-6 hidden rounded-2xl border border-red-200 bg-red-50 p-4 text-red-900" role="alert" aria-live="polite"></p>

			<form data-login-form class="mt-8 space-y-5">
				<label class="block">
					<span class="text-sm font-medium text-stone-800">Username</span>
					<input
						type="text"
						name="username"
						required
						minlength="3"
						maxlength="30"
						autocomplete="username"
						autocapitalize="none"
						spellcheck="false"
						class="mt-2 w-full rounded-xl border border-stone-300 bg-white px-4 py-3 outline-none focus:border-rosewood focus:ring-2 focus:ring-rose-100"
					/>
				</label>

				<label class="block">
					<span class="text-sm font-medium text-stone-800">Password</span>
					<input
						type="password"
						name="password"
						required
						maxlength="128"
						autocomplete="current-password"
						class="mt-2 w-full rounded-xl border border-stone-300 bg-white px-4 py-3 outline-none focus:border-rosewood focus:ring-2 focus:ring-rose-100"
					/>
				</label>

				<button data-login-submit type="submit" class="w-full rounded-xl bg-rosewood px-4 py-3 font-semibold text-white transition hover:bg-rose-800 focus:outline-none focus:ring-2 focus:ring-rose-300 focus:ring-offset-2 disabled:cursor-wait disabled:opacity-60">
					Sign in
				</button>
			</form>
		</section>
	</main>
</BaseLayout>

<script>
	import { authClient } from '../lib/auth-client';

	const form = document.querySelector<HTMLFormElement>('[data-login-form]');
	const status = document.querySelector<HTMLElement>('[data-login-status]');
	const submit = document.querySelector<HTMLButtonElement>('[data-login-submit]');

	form?.addEventListener('submit', async (event) => {
		event.preventDefault();

		if (!status || !submit) return;

		status.classList.add('hidden');
		status.textContent = '';
		submit.disabled = true;

		const formData = new FormData(form);
		const username = formData.get('username');
		const password = formData.get('password');

		if (typeof username !== 'string' || typeof password !== 'string') {
			status.textContent = 'Enter your username and password.';
			status.classList.remove('hidden');
			submit.disabled = false;
			return;
		}

		try {
			const { error } = await authClient.signIn.username({
				username: username.trim(),
				password,
			});

			if (!error) {
				window.location.assign('/account');
				return;
			}
		} catch {
			// Use the same message for invalid credentials and network failures.
		} finally {
			submit.disabled = false;
		}

		status.textContent = 'The username or password is incorrect, or this account is unavailable.';
		status.classList.remove('hidden');
	});
</script>
