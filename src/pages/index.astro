---
import PostCard from '../components/PostCard.astro';
import { listPublicPosts } from '../db/post-queries';
import BaseLayout from '../layouts/BaseLayout.astro';
import { decodePostCursor } from '../lib/post';

const cursorValues = Astro.url.searchParams.getAll('cursor');
const cursor = cursorValues[0] ?? null;

if (cursorValues.length > 1 || (cursor && !decodePostCursor(cursor))) {
	return Astro.redirect('/');
}

const page = await listPublicPosts(Astro.locals.database, cursor);
const nextPageUrl = page.nextCursor ? `/?cursor=${encodeURIComponent(page.nextCursor)}` : null;
---

<BaseLayout title="LoveNote · Shared moments">
	<header class="border-b border-stone-200 bg-white">
		<div class="mx-auto flex w-full max-w-3xl items-center justify-between px-5 py-4 sm:px-8">
			<a href="/" class="font-semibold tracking-tight text-stone-950">LoveNote</a>
			<a href="/login" class="text-sm font-medium text-rosewood hover:text-rose-800">Member sign in</a>
		</div>
	</header>

	<main class="mx-auto w-full max-w-3xl px-5 py-10 sm:px-8 sm:py-14">
		<section aria-labelledby="feed-heading">
			<p class="text-sm font-semibold tracking-[0.16em] text-rosewood uppercase">Public feed</p>
			<h1 id="feed-heading" class="mt-2 text-4xl font-semibold tracking-tight text-stone-950">Shared moments</h1>
			<p class="mt-3 max-w-2xl text-lg leading-8 text-stone-600">Words, photographs, and videos shared by our small circle.</p>

			{page.items.length === 0 ? (
				<div class="mt-10 rounded-3xl border border-dashed border-stone-300 bg-white p-10 text-center text-stone-600">
					No public posts have been shared yet.
				</div>
			) : (
				<div class="mt-10 space-y-8">
					{page.items.map((post, index) => (
						<PostCard post={post} detailHref={`/posts/${post.id}`} eagerFirstMedia={index === 0} />
					))}
				</div>
			)}

			{nextPageUrl && (
				<nav class="mt-10 flex justify-center" aria-label="Feed pagination">
					<a href={nextPageUrl} rel="next" class="rounded-xl border border-stone-300 bg-white px-5 py-3 font-semibold text-stone-800 shadow-sm hover:border-stone-400 hover:text-stone-950">
						Older posts
					</a>
				</nav>
			)}
		</section>
	</main>

	<footer class="border-t border-stone-200 px-5 py-8 text-center text-sm text-stone-500">
		Public posts can be viewed without an account.
	</footer>
</BaseLayout>
