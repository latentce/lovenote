---
import { actions, isInputError } from 'astro:actions';

import BaseLayout from '../layouts/BaseLayout.astro';
import { isSetupAvailable } from '../lib/setup';

Astro.cache.set(false);
Astro.response.headers.set('Cache-Control', 'private, no-store');
Astro.response.headers.set('Pragma', 'no-cache');

const result = Astro.getActionResult(actions.setup.create);
const wasCreated = result?.data?.created === true;
const available = wasCreated ? false : await isSetupAvailable(Astro.locals.database);
const inputErrors = isInputError(result?.error) ? result.error.fields : {};
---

<BaseLayout title="Set up LoveNote">
	<main class="mx-auto flex min-h-screen w-full max-w-xl items-center px-5 py-12 sm:px-8">
		<section class="w-full rounded-3xl border border-stone-200 bg-white p-7 shadow-sm sm:p-10">
			<p class="text-sm font-semibold tracking-[0.16em] text-rosewood uppercase">LoveNote</p>
			<h1 class="mt-3 text-3xl font-semibold tracking-tight text-stone-900">Create the owner</h1>

			{wasCreated ? (
				<div class="mt-6 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900" role="status">
					Owner created. <a href="/login" class="font-semibold underline">Sign in with your username.</a>
				</div>
			) : !available ? (
				<div class="mt-6 rounded-2xl border border-stone-200 bg-stone-50 p-4 text-stone-700" role="status">
					Setup has already been completed.
				</div>
			) : (
				<>
					<p class="mt-3 text-stone-600">
						This one-time form creates the only account that can manage members and site settings.
					</p>

					{result?.error && !isInputError(result.error) && (
						<div class="mt-6 rounded-2xl border border-red-200 bg-red-50 p-4 text-red-900" role="alert">
							{result.error.message}
						</div>
					)}

					<form method="POST" action={actions.setup.create} class="mt-8 space-y-5">
						<label class="block">
							<span class="text-sm font-medium text-stone-800">Setup secret</span>
							<input
								type="password"
								name="setupSecret"
								required
								autocomplete="off"
								aria-describedby={inputErrors.setupSecret ? 'setup-secret-error' : undefined}
								class="mt-2 w-full rounded-xl border border-stone-300 bg-white px-4 py-3 outline-none focus:border-rosewood focus:ring-2 focus:ring-rose-100"
							/>
							{inputErrors.setupSecret && <span id="setup-secret-error" class="mt-1 block text-sm text-red-700">{inputErrors.setupSecret.join(' ')}</span>}
						</label>

						<label class="block">
							<span class="text-sm font-medium text-stone-800">Username</span>
							<input
								type="text"
								name="username"
								required
								minlength="3"
								maxlength="30"
								autocomplete="username"
								spellcheck="false"
								aria-describedby={inputErrors.username ? 'username-error' : undefined}
								class="mt-2 w-full rounded-xl border border-stone-300 bg-white px-4 py-3 outline-none focus:border-rosewood focus:ring-2 focus:ring-rose-100"
							/>
							{inputErrors.username && <span id="username-error" class="mt-1 block text-sm text-red-700">{inputErrors.username.join(' ')}</span>}
						</label>

						<label class="block">
							<span class="text-sm font-medium text-stone-800">Password</span>
							<input
								type="password"
								name="password"
								required
								minlength="12"
								maxlength="128"
								autocomplete="new-password"
								aria-describedby={inputErrors.password ? 'password-error' : undefined}
								class="mt-2 w-full rounded-xl border border-stone-300 bg-white px-4 py-3 outline-none focus:border-rosewood focus:ring-2 focus:ring-rose-100"
							/>
							{inputErrors.password && <span id="password-error" class="mt-1 block text-sm text-red-700">{inputErrors.password.join(' ')}</span>}
						</label>

						<label class="block">
							<span class="text-sm font-medium text-stone-800">Confirm password</span>
							<input
								type="password"
								name="confirmPassword"
								required
								minlength="12"
								maxlength="128"
								autocomplete="new-password"
								aria-describedby={inputErrors.confirmPassword ? 'confirm-password-error' : undefined}
								class="mt-2 w-full rounded-xl border border-stone-300 bg-white px-4 py-3 outline-none focus:border-rosewood focus:ring-2 focus:ring-rose-100"
							/>
							{inputErrors.confirmPassword && <span id="confirm-password-error" class="mt-1 block text-sm text-red-700">{inputErrors.confirmPassword.join(' ')}</span>}
						</label>

						<button type="submit" class="w-full rounded-xl bg-rosewood px-4 py-3 font-semibold text-white transition hover:bg-rose-800 focus:outline-none focus:ring-2 focus:ring-rose-300 focus:ring-offset-2">
							Create owner
						</button>
					</form>
				</>
			)}
		</section>
	</main>
</BaseLayout>
