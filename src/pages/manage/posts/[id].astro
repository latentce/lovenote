---
import { actions, isInputError } from 'astro:actions';

import { findOwnPostForEdit } from '../../../db/post-queries';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { hasCapability, isActiveMember } from '../../../lib/authorization';
import { MAX_POST_BODY_LENGTH } from '../../../lib/post';

Astro.cache.set(false);
Astro.response.headers.set('Cache-Control', 'private, no-store');
Astro.response.headers.set('Pragma', 'no-cache');

if (!isActiveMember(Astro.locals.user)) {
	return Astro.redirect('/login');
}

const idValue = Astro.params.id ?? '';
const postId = /^[1-9]\d*$/u.test(idValue) ? Number(idValue) : Number.NaN;
const post = Number.isSafeInteger(postId)
	? await findOwnPostForEdit(Astro.locals.database, Astro.locals.user.id, postId)
	: null;

if (!post) {
	Astro.response.status = 404;
	Astro.response.statusText = 'Not Found';
}

const result = Astro.getActionResult(actions.posts.update);
const inputErrors = isInputError(result?.error) ? result.error.fields : {};
const success = Boolean(post && result?.data?.postId === post.id && result.data.cachePurged);
const cacheWarning = Boolean(
	post && result?.data?.postId === post.id && result.data.cachePurged === false,
);
const errorMessage = result?.error && !isInputError(result.error) ? result.error.message : null;
const canEdit = hasCapability(Astro.locals, 'editOwnPosts');
---

<BaseLayout title={post ? `Edit post #${post.id} · LoveNote` : 'Post not found · LoveNote'}>
	<header class="border-b border-stone-200 bg-white">
		<div class="mx-auto flex w-full max-w-3xl items-center justify-between gap-5 px-5 py-4 sm:px-8">
			<a href="/" class="font-semibold tracking-tight text-stone-950">LoveNote</a>
			<a href="/manage" class="text-sm font-medium text-rosewood hover:text-rose-800">Author tools</a>
		</div>
	</header>

	<main class="mx-auto w-full max-w-3xl px-5 py-10 sm:px-8 sm:py-14">
		{post ? (
			<>
				<p class="text-sm font-semibold tracking-[0.16em] text-rosewood uppercase">Author tools</p>
				<div class="mt-2 flex flex-wrap items-center justify-between gap-3">
					<h1 class="text-3xl font-semibold tracking-tight text-stone-950">Edit post #{post.id}</h1>
					{post.status === 'hidden' && (
						<span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold tracking-wide text-amber-900 uppercase">Hidden</span>
					)}
				</div>
				<p class="mt-3 text-stone-600">Attachments remain unchanged. Use the visibility control to choose who can read the post and access its media.</p>

				{success && (
					<p class="mt-7 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900" role="status">Post saved.</p>
				)}
				{cacheWarning && (
					<p class="mt-7 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-amber-950" role="alert">The post was saved, but cached copies could not be cleared. Submit the form again to retry the purge.</p>
				)}
				{errorMessage && (
					<p class="mt-7 rounded-2xl border border-red-200 bg-red-50 p-4 text-red-900" role="alert">{errorMessage}</p>
				)}

				{!canEdit ? (
					<div class="mt-8 rounded-2xl border border-amber-200 bg-amber-50 p-5 text-amber-950">
						You cannot edit posts with the current account permissions. If you still have a temporary password,
						<a href="/account" class="font-semibold underline">change it from your account page</a>.
					</div>
				) : (
					<form method="POST" action={actions.posts.update} class="mt-8 space-y-7 rounded-3xl border border-stone-200 bg-white p-6 shadow-sm sm:p-9">
						<input type="hidden" name="postId" value={post.id} />
						{cacheWarning && result?.data?.purgePublic && (
							<input type="hidden" name="purgePublic" value="true" />
						)}
						<label class="block">
							<span class="text-sm font-medium text-stone-800">Post text</span>
							<textarea
								name="body"
								rows="10"
								maxlength={MAX_POST_BODY_LENGTH}
								aria-describedby={inputErrors.body ? 'edit-body-error' : 'edit-body-help'}
								class="mt-2 w-full resize-y rounded-xl border border-stone-300 bg-white px-4 py-3 leading-7 outline-none focus:border-rosewood focus:ring-2 focus:ring-rose-100"
							>{post.body}</textarea>
							<span id="edit-body-help" class="mt-1 block text-sm text-stone-500">
								Plain text, up to {MAX_POST_BODY_LENGTH.toLocaleString()} characters.
								{post.hasMedia ? ' This post can remain text-free because it has media.' : ' This text cannot be empty because the post has no media.'}
							</span>
							{inputErrors.body && <span id="edit-body-error" class="mt-1 block text-sm text-red-700">{inputErrors.body.join(' ')}</span>}
						</label>

						<label class="block">
							<span class="text-sm font-medium text-stone-800">Visibility</span>
							<select name="visibility" class="mt-2 w-full rounded-xl border border-stone-300 bg-white px-4 py-3 outline-none focus:border-rosewood focus:ring-2 focus:ring-rose-100">
								<option value="private" selected={post.visibility === 'private'}>Private — all active members</option>
								<option value="public" selected={post.visibility === 'public'}>Public — anyone</option>
							</select>
							{inputErrors.visibility && <span class="mt-1 block text-sm text-red-700">{inputErrors.visibility.join(' ')}</span>}
						</label>

						<button type="submit" class="rounded-xl bg-rosewood px-5 py-3 font-semibold text-white transition hover:bg-rose-800 focus:outline-none focus:ring-2 focus:ring-rose-300 focus:ring-offset-2">Save changes</button>
					</form>
				)}
			</>
		) : (
			<section class="rounded-3xl border border-stone-200 bg-white p-10 text-center shadow-sm">
				<p class="text-sm font-semibold tracking-[0.16em] text-rosewood uppercase">404</p>
				<h1 class="mt-2 text-3xl font-semibold tracking-tight text-stone-950">Post not found</h1>
				<p class="mt-3 text-stone-600">This post does not exist, does not belong to you, or is awaiting deletion.</p>
				<a href="/manage" class="mt-6 inline-block font-semibold text-rosewood hover:text-rose-800">Return to author tools</a>
			</section>
		)}
	</main>
</BaseLayout>
