---
import PostCard from '../../components/PostCard.astro';
import { findPublicTag, listPublicTagPosts } from '../../db/tag-queries';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { decodePostCursor } from '../../lib/post';

const slug = Astro.params.slug ?? '';
const cursorValues = Astro.url.searchParams.getAll('cursor');
const cursor = cursorValues[0] ?? null;

if (cursorValues.length > 1 || (cursor && !decodePostCursor(cursor))) {
	return Astro.redirect(`/tags/${encodeURIComponent(slug)}`);
}

const tag = slug.length <= 64 ? await findPublicTag(Astro.locals.database, slug) : null;
const page = tag ? await listPublicTagPosts(Astro.locals.database, tag.id, cursor) : null;

if (!tag || !page) {
	Astro.response.status = 404;
	Astro.response.statusText = 'Not Found';
	Astro.cache.set(false);
	Astro.response.headers.set('Cache-Control', 'private, no-store');
} else if (Astro.cache.enabled) {
	Astro.cache.set({ tags: [`tag:${tag.id}`] });
}

const nextPageUrl = tag && page?.nextCursor
	? `/tags/${encodeURIComponent(tag.slug)}?cursor=${encodeURIComponent(page.nextCursor)}`
	: null;
const title = tag ? `#${tag.displayName} · LoveNote` : 'Tag not found · LoveNote';
const description = tag?.description || (tag
	? `Browse public LoveNote posts tagged ${tag.displayName}.`
	: 'This LoveNote tag is not available.');
---

<BaseLayout title={title} description={description}>
	<header class="border-b border-stone-200 bg-white">
		<div class="mx-auto flex w-full max-w-3xl items-center justify-between gap-5 px-5 py-4 sm:px-8">
			<a href="/" class="font-semibold tracking-tight text-stone-950">LoveNote</a>
			<a href="/tags" class="text-sm font-medium text-rosewood hover:text-rose-800">All tags</a>
		</div>
	</header>

	<main class="mx-auto w-full max-w-3xl px-5 py-10 sm:px-8 sm:py-14">
		{tag && page ? (
			<section aria-labelledby="tag-heading">
				<p class="text-sm font-semibold tracking-[0.16em] text-rosewood uppercase">Public tag</p>
				<h1 id="tag-heading" class="mt-2 text-4xl font-semibold tracking-tight text-stone-950">#{tag.displayName}</h1>
				<p class="mt-3 text-stone-600">{tag.postCount} public {tag.postCount === 1 ? 'post' : 'posts'}</p>
				{tag.description && <p class="mt-3 max-w-2xl text-lg leading-8 text-stone-600">{tag.description}</p>}

				<div class="mt-10 space-y-8">
					{page.items.map((post, index) => (
						<PostCard post={post} detailHref={`/posts/${post.id}`} eagerFirstMedia={index === 0} />
					))}
				</div>

				{nextPageUrl && (
					<nav class="mt-10 flex justify-center" aria-label="Tag pagination">
						<a href={nextPageUrl} rel="next" class="rounded-xl border border-stone-300 bg-white px-5 py-3 font-semibold text-stone-800 shadow-sm hover:border-stone-400 hover:text-stone-950">
							Older posts
						</a>
					</nav>
				)}
			</section>
		) : (
			<section class="rounded-3xl border border-stone-200 bg-white p-10 text-center shadow-sm">
				<p class="text-sm font-semibold tracking-[0.16em] text-rosewood uppercase">404</p>
				<h1 class="mt-2 text-3xl font-semibold tracking-tight text-stone-950">Tag not found</h1>
				<p class="mt-3 text-stone-600">This tag does not exist, or it has no public posts.</p>
				<a href="/tags" class="mt-6 inline-block font-semibold text-rosewood hover:text-rose-800">Browse public tags</a>
			</section>
		)}
	</main>
</BaseLayout>
