---
import { listPublicTags } from '../../db/tag-queries';
import BaseLayout from '../../layouts/BaseLayout.astro';

const tags = await listPublicTags(Astro.locals.database);
---

<BaseLayout title="Tags · LoveNote" description="Browse the topics attached to public LoveNote posts.">
	<header class="border-b border-stone-200 bg-white">
		<div class="mx-auto flex w-full max-w-4xl items-center justify-between gap-5 px-5 py-4 sm:px-8">
			<a href="/" class="font-semibold tracking-tight text-stone-950">LoveNote</a>
			<nav class="flex items-center gap-5 text-sm font-medium" aria-label="Public navigation">
				<a href="/" class="text-stone-600 hover:text-stone-950">Feed</a>
				<a href="/archive" class="text-stone-600 hover:text-stone-950">Media</a>
				<a href="/login" class="text-rosewood hover:text-rose-800">Member sign in</a>
			</nav>
		</div>
	</header>

	<main class="mx-auto w-full max-w-4xl px-5 py-10 sm:px-8 sm:py-14">
		<section aria-labelledby="tags-heading">
			<p class="text-sm font-semibold tracking-[0.16em] text-rosewood uppercase">Public tags</p>
			<h1 id="tags-heading" class="mt-2 text-4xl font-semibold tracking-tight text-stone-950">Browse by topic</h1>
			<p class="mt-3 max-w-2xl text-lg leading-8 text-stone-600">Only tags used on public posts are listed here.</p>

			{tags.length === 0 ? (
				<div class="mt-10 rounded-3xl border border-dashed border-stone-300 bg-white p-10 text-center text-stone-600">
					No public tags are available yet.
				</div>
			) : (
				<ul class="mt-10 grid gap-5 sm:grid-cols-2">
					{tags.map((tag) => (
						<li>
							<a href={`/tags/${encodeURIComponent(tag.slug)}`} class="block h-full rounded-3xl border border-stone-200 bg-white p-6 shadow-sm transition hover:border-stone-300 hover:shadow-md">
								<div class="flex items-baseline justify-between gap-4">
									<h2 class="text-xl font-semibold text-stone-950">#{tag.displayName}</h2>
									<span class="text-sm text-stone-500">{tag.postCount} {tag.postCount === 1 ? 'post' : 'posts'}</span>
								</div>
								{tag.description && <p class="mt-3 leading-7 text-stone-600">{tag.description}</p>}
							</a>
						</li>
					))}
				</ul>
			)}
		</section>
	</main>
</BaseLayout>
