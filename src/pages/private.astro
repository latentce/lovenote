---
import LogoutButton from '../components/LogoutButton.astro';
import PostCard from '../components/PostCard.astro';
import { listPrivatePosts } from '../db/post-queries';
import BaseLayout from '../layouts/BaseLayout.astro';
import { isActiveMember } from '../lib/authorization';
import { decodePostCursor } from '../lib/post';

Astro.cache.set(false);
Astro.response.headers.set('Cache-Control', 'private, no-store');
Astro.response.headers.set('Pragma', 'no-cache');

if (!isActiveMember(Astro.locals.user)) {
	return Astro.redirect('/login');
}

const cursorValues = Astro.url.searchParams.getAll('cursor');
const cursor = cursorValues[0] ?? null;

if (cursorValues.length > 1 || (cursor && !decodePostCursor(cursor))) {
	return Astro.redirect('/private');
}

const page = await listPrivatePosts(Astro.locals.database, Astro.locals.user, cursor);
const nextPageUrl = page.nextCursor
	? `/private?cursor=${encodeURIComponent(page.nextCursor)}`
	: null;
---

<BaseLayout title="Private feed · LoveNote" description="Private posts shared with active LoveNote members.">
	<header class="border-b border-stone-200 bg-white">
		<div class="mx-auto flex w-full max-w-3xl items-center justify-between gap-5 px-5 py-4 sm:px-8">
			<a href="/" class="font-semibold tracking-tight text-stone-950">LoveNote</a>
			<nav class="flex items-center gap-4 text-sm" aria-label="Member navigation">
				<a href="/" class="text-stone-600 hover:text-stone-950">Public feed</a>
				<a href="/manage" class="text-stone-600 hover:text-stone-950">Create</a>
				<a href="/account" class="text-stone-600 hover:text-stone-950">Account</a>
				<LogoutButton />
			</nav>
		</div>
	</header>

	<main class="mx-auto w-full max-w-3xl px-5 py-10 sm:px-8 sm:py-14">
		<section aria-labelledby="private-feed-heading">
			<p class="text-sm font-semibold tracking-[0.16em] text-rosewood uppercase">Members only</p>
			<h1 id="private-feed-heading" class="mt-2 text-4xl font-semibold tracking-tight text-stone-950">Private feed</h1>
			<p class="mt-3 max-w-2xl text-lg leading-8 text-stone-600">Posts shared with the active members of this group.</p>

			{page.items.length === 0 ? (
				<div class="mt-10 rounded-3xl border border-dashed border-stone-300 bg-white p-10 text-center text-stone-600">
					No private posts have been shared yet.
				</div>
			) : (
				<div class="mt-10 space-y-8">
					{page.items.map((post, index) => (
						<div>
							{post.status === 'hidden' && (
								<p class="mb-2 text-sm font-semibold text-amber-800">Hidden from other members</p>
							)}
							<PostCard post={post} detailHref={`/posts/${post.id}`} eagerFirstMedia={index === 0} />
						</div>
					))}
				</div>
			)}

			{nextPageUrl && (
				<nav class="mt-10 flex justify-center" aria-label="Private feed pagination">
					<a href={nextPageUrl} rel="next" class="rounded-xl border border-stone-300 bg-white px-5 py-3 font-semibold text-stone-800 shadow-sm hover:border-stone-400 hover:text-stone-950">
						Older posts
					</a>
				</nav>
			)}
		</section>
	</main>
</BaseLayout>
