---
import { hasCapability, isActiveMember } from '../lib/authorization';
import CommentComposer from './CommentComposer.astro';

interface Props {
	bodyErrors?: string[];
	errorMessage?: string | null;
	postId: number;
	success?: boolean;
}

Astro.cache.set(false);
Astro.response.headers.set('Cache-Control', 'private, no-store');

const props = Astro.props;
const activeMember = isActiveMember(Astro.locals.user);
const canComment = hasCapability(Astro.locals, 'createComments');
---

{!activeMember ? (
	<div class="rounded-3xl border border-stone-200 bg-white p-5 text-stone-600 shadow-sm sm:p-7">
		<a href="/login" class="font-semibold text-rosewood hover:text-rose-800">Sign in</a> to add a comment.
	</div>
) : canComment ? (
	<CommentComposer {...props} />
) : (
	<div class="rounded-3xl border border-amber-200 bg-amber-50 p-5 text-amber-950 sm:p-7">
		You cannot comment with the current account permissions. If you still have a temporary password,
		<a href="/account" class="font-semibold underline">change it from your account page</a>.
	</div>
)}
