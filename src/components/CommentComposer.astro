---
import { actions } from 'astro:actions';

import { MAX_COMMENT_BODY_LENGTH } from '../lib/comment';

interface Props {
	bodyErrors?: string[];
	errorMessage?: string | null;
	postId: number;
	success?: boolean;
}

const { bodyErrors = [], errorMessage, postId, success = false } = Astro.props;
---

<div class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm sm:p-7">
	{success && <p class="mb-5 rounded-xl bg-emerald-50 p-3 text-sm text-emerald-900" role="status">Your comment was added.</p>}
	{errorMessage && <p class="mb-5 rounded-xl bg-red-50 p-3 text-sm text-red-900" role="alert">{errorMessage}</p>}
	<form method="POST" action={actions.comments.create}>
		<input type="hidden" name="postId" value={postId} />
		<label class="block">
			<span class="text-sm font-semibold text-stone-900">Add a comment</span>
			<textarea
				name="body"
				required
				rows="4"
				maxlength={MAX_COMMENT_BODY_LENGTH}
				aria-describedby={bodyErrors.length > 0 ? 'comment-body-error' : 'comment-body-help'}
				class="mt-2 w-full resize-y rounded-xl border border-stone-300 bg-white px-4 py-3 leading-7 outline-none focus:border-rosewood focus:ring-2 focus:ring-rose-100"
			></textarea>
			<span id="comment-body-help" class="mt-1 block text-xs text-stone-500">Plain text, up to {MAX_COMMENT_BODY_LENGTH.toLocaleString()} characters.</span>
			{bodyErrors.length > 0 && <span id="comment-body-error" class="mt-1 block text-sm text-red-700">{bodyErrors.join(' ')}</span>}
		</label>
		<button type="submit" class="mt-4 rounded-xl bg-rosewood px-5 py-3 font-semibold text-white transition hover:bg-rose-800 focus:outline-none focus:ring-2 focus:ring-rose-300 focus:ring-offset-2">
			Post comment
		</button>
	</form>
</div>
