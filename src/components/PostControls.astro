---
import { isPostFavorited } from '../db/favorite-mutations';
import { hasCapability, isActiveMember } from '../lib/authorization';
import CommentComposer from './CommentComposer.astro';
import FavoriteForm from './FavoriteForm.astro';

interface Props {
	bodyErrors?: string[];
	commentError?: string | null;
	commentSuccess?: boolean;
	favoriteError?: string | null;
	favoriteSuccess?: string | null;
	postId: number;
}

Astro.cache.set(false);
Astro.response.headers.set('Cache-Control', 'private, no-store');

const props = Astro.props;
const user = Astro.locals.user;
const activeMember = isActiveMember(user);
const canComment = hasCapability(Astro.locals, 'createComments');
const canFavorite = hasCapability(Astro.locals, 'favoritePosts');
const favorited = activeMember && canFavorite
	? await isPostFavorited(Astro.locals.database, user.id, props.postId)
	: false;
---

{!activeMember ? (
	<div class="rounded-3xl border border-stone-200 bg-white p-5 text-stone-600 shadow-sm sm:p-7">
		<a href="/login" class="font-semibold text-rosewood hover:text-rose-800">Sign in</a> to favorite this post or add a comment.
	</div>
) : (
	<div class="space-y-5">
		{canFavorite ? (
			<FavoriteForm
				postId={props.postId}
				favorited={favorited}
				errorMessage={props.favoriteError}
				successMessage={props.favoriteSuccess}
			/>
		) : (
			<div class="rounded-3xl border border-amber-200 bg-amber-50 p-5 text-amber-950 sm:p-7">
				You cannot favorite posts with the current account permissions. If you still have a temporary password,
				<a href="/account" class="font-semibold underline">change it from your account page</a>.
			</div>
		)}

		{canComment ? (
			<CommentComposer
				postId={props.postId}
				bodyErrors={props.bodyErrors}
				errorMessage={props.commentError}
				success={props.commentSuccess}
			/>
		) : (
			<div class="rounded-3xl border border-amber-200 bg-amber-50 p-5 text-amber-950 sm:p-7">
				You cannot comment with the current account permissions. If you still have a temporary password,
				<a href="/account" class="font-semibold underline">change it from your account page</a>.
			</div>
		)}
	</div>
)}
