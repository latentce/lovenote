{
  "name": "lovenote",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "astro dev --background",
    "dev:stop": "astro dev stop",
    "dev:status": "astro dev status",
    "dev:logs": "astro dev logs",
    "typegen": "wrangler types worker-configuration.d.ts --include-runtime false",
    "db:auth-schema": "auth generate --config src/auth.cli.ts --output src/db/auth-schema.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "owner:recover": "tsx scripts/recover-owner-password.ts",
    "config:check": "tsx scripts/verify-production-config.ts",
    "check": "astro check",
    "test": "vitest run",
    "test:worker": "vitest run --config vitest.worker.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:local": "tsx scripts/run-local-integration.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:acceptance": "tsx scripts/verify-acceptance-environment.ts && LOVENOTE_ACCEPTANCE=1 CLOUDFLARE_ENV=acceptance pnpm build && playwright test",
    "test:acceptance:smoke": "E2E_MUTATIONS=0 E2E_UPLOADS=0 LOVENOTE_ACCEPTANCE=1 CLOUDFLARE_ENV=acceptance pnpm build && playwright test",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "deploy": "pnpm config:check && pnpm build && wrangler deploy",
    "tail": "wrangler tail",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.3",
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.9",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@cloudflare/workers-types": "^5.20260714.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "auth": "^1.6.23",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
